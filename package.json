    "configuration": {
      "title": "VSCode Flash Jump",
      "properties": {
        "flashFind.labels": {
          "type": "string",
          "default": "asdfghjklqwertyuiopzxcvbnm",
          "description": "Characters used to generate jump labels."
        },
        "flashFind.maxMatches": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "maximum": 1000,
          "description": "Maximum visible matches to label."
        },
        "flashFind.caseSensitive": {
          "type": "boolean",
          "default": false,
          "description": "Search with case-sensitive literal matching."
        },
        "flashFind.minQueryLength": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 16,
          "description": "Minimum query length before showing matches."
        }
      }
