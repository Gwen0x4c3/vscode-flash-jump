{
  "name": "vscode-flash-jump",
  "displayName": "VSCode Flash Jump",
  "description": "flash.nvim-style jump labels for fast VSCodeVim navigation.",
  "version": "0.1.0",
  "publisher": "Gwen0x4c3",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gwen0x4c3/vscode-flash-jump.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:flashFind.start",
    "onCommand:flashFind.cancel",
    "onCommand:flashFind.backspace"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flashFind.start",
        "title": "VSCode Flash Jump: Start"
      },
      {
        "command": "flashFind.cancel",
        "title": "VSCode Flash Jump: Cancel"
      },
      {
        "command": "flashFind.backspace",
        "title": "VSCode Flash Jump: Backspace"
      },
      {
        "command": "flashFind.input",
        "title": "VSCode Flash Jump: Input"
      }
    ],
    "keybindings": [
      {
        "command": "flashFind.cancel",
        "key": "escape",
        "when": "editorTextFocus && flashFind.active"
      },
      {
        "command": "flashFind.backspace",
        "key": "backspace",
        "mac": "backspace",
        "when": "editorTextFocus && flashFind.active"
      },
      {
        "command": "flashFind.input",
        "key": "a",
        "args": { "text": "a" },
